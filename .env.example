# Copie ce fichier en .env (à côté du docker-compose que tu utilises) puis renseigne les vraies valeurs.
# Le fichier .env ne doit JAMAIS être commité (déjà ignoré par .gitignore).

# Clé secrète utilisée pour signer les tokens JWT.
# Désormais OPTIONNELLE : le backend persiste une clé stable dans data/.jwt_secret
# (survit aux redéploiements). Si tu renseignes une valeur ici, elle sert seulement
# à initialiser cette clé au tout premier démarrage. Génère-la avec : openssl rand -hex 32
JWT_SECRET=

# Mot de passe du compte admin créé automatiquement au tout premier démarrage
# (ignoré si backend/data/users.json existe déjà, ce qui est le cas sur une install existante).
ADMIN_DEFAULT_PASSWORD=

# Token du tunnel Cloudflare — uniquement nécessaire pour docker-compose.nas.yml.
CLOUDFLARE_TUNNEL_TOKEN=

# Clé de chiffrement des médias au repos (photos/vidéos), 32 octets en hexadécimal.
# Génère-la avec : openssl rand -hex 32
# ATTENTION : une fois des médias chiffrés avec cette clé, la perdre les rend
# illisibles. Sauvegarde-la. Si vide, les médias sont stockés en clair.
MEDIA_ENCRYPTION_KEY=
